log none
variable dumpfreq         equal    1
variable restart          equal    0
variable neighborSkinDist equal    1.0 # distance for bins beyond force cut-off (1.0 = 1.0 Ang for units = real) 
variable baseFilename     universe Model

# Initialization
units           real
boundary        p p p
atom_style      angle 
log             Model.LAMMPS_logFile
read_data       Model.LAMMPS_read_data 

# Dreiding potential information
neighbor        1.2 bin
neigh_modify    every 10 one 10000

bond_style      harmonic
bond_coeff      1   9934.817   0.700
bond_coeff      2   2250.785   0.456 
bond_coeff      3   4860.383   0.502 
angle_style     harmonic
angle_coeff     1   51.084    99.085
angle_coeff     2   27.469    128.857
angle_coeff     3   37.735    106.014
pair_style      lj/cut 1
pair_coeff      1  1  1  0.542  0.542
pair_coeff      1  2  1  0.422  0.422
pair_coeff      1  3  1  0.563  0.563
pair_coeff      1  4  1  0.637  0.637
pair_coeff      2  2  1  0.302  0.302
pair_coeff      2  3  1  0.443  0.443
pair_coeff      2  4  1  0.517  0.517
pair_coeff      3  3  1  0.584  0.584
pair_coeff      3  4  1  0.658  0.658
pair_coeff      4  4  1  0.732  0.732

thermo_style custom step etotal
# thermo 1000

#fix 1 all SELM ${baseFilename}.SELM_params

dump  1  all dcd ${dumpfreq} Model.dcd 

timestep 0.001
#run      100
